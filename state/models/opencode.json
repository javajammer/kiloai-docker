{
  "$schema": "https://kilo.ai/config.json",
  "model": "apertis/cobuddy:free",
  "small_model": "apertis/gemma-3-27b-it:free",
  "theme": "catppuccin",
  "autoupdate": true,
  "share": "manual",
  "snapshot": true,
  "logLevel": "INFO",
  "provider": {
    "apertis": {
      "options": {
        "apiKey": "ganti-dengan-key-kalian",
        "baseURL": "https://api.apertis.ai/v1"
      },
      "models": {
        "cobuddy:free": {
          "id": "cobuddy:free",
          "name": "Cobuddy Free (via Apertis)"
        },
        "nemotron-3-super-120b-a12b:free": {
          "id": "nemotron-3-super-120b-a12b:free",
          "name": "Nemotron 3 Super 120B (via Apertis)"
        },
        "deepseek-v3:free": {
          "id": "deepseek-v3:free",
          "name": "DeepSeek V3 (via Apertis)"
        },
        "kimi-dev-72b:free": {
          "id": "kimi-dev-72b:free",
          "name": "Kimi Dev 72B (via Apertis)"
        },
        "llama-3.1-nemotron-ultra-253b-v1:free": {
          "id": "llama-3.1-nemotron-ultra-253b-v1:free",
          "name": "Llama 3.1 Nemotron Ultra 253B (via Apertis)"
        },
        "llama-3.3-nemotron-super-49b-v1:free": {
          "id": "llama-3.3-nemotron-super-49b-v1:free",
          "name": "Llama 3.3 Nemotron Super 49B (via Apertis)"
        },
        "gemma-3-27b-it:free": {
          "id": "gemma-3-27b-it:free",
          "name": "Gemma 3 27B (via Apertis)"
        },
        "qwen3-235b-a22b:free": {
          "id": "qwen3-235b-a22b:free",
          "name": "Qwen3 235B (via Apertis)"
        },
        "qwen3-coder:free": {
          "id": "qwen3-coder:free",
          "name": "Qwen3 Coder (via Apertis)"
        },
        "nova-2-lite-v1:free": {
          "id": "nova-2-lite-v1:free",
          "name": "Nova 2 Lite V1 (via Apertis)"
        },
        "gemma-4-31b-it:free": {
          "id": "gemma-4-31b-it:free",
          "name": "Gemma 4 31B (via Apertis)"
        }
      }
    },
    "cerebras": {
      "options": {
        "apiKey": "ganti-dengan-key-kalian",
        "baseURL": "https://api.cerebras.ai/v1"
      }
    }
  },
  "agent": {
    "build": {
      "model": "openai/gpt-5.4-mini-fast",
      "temperature": 0.7,
      "maxSteps": 100,
      "permission": {
        "edit": "allow",
        "bash": {
          "npm": "allow",
          "git": "allow",
          "go": "allow",
          "make": "allow",
          "*": "ask"
        },
        "webfetch": "allow"
      }
    },
    "plan": {
      "model": "openai/gpt-5.4-mini-fast",
      "permission": {
        "edit": "deny",
        "bash": "ask"
      }
    }
  },
  "mcp": {
    "context7": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp@latest"
      ],
      "enabled": true
    },
    "shodan": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@tocharianou/mcp-shodan"
      ],
      "enabled": true,
      "environment": {
        "SHODAN_API_KEY": "ganti-dengan-key-kalian"
      }
    },
    "sequential-thinking": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "enabled": true
    },
    "cve-mcp": {
      "type": "local",
      "command": [
        "python3",
        "/home/USER/.config/kilo/mcp/CVE-MCP/main.py",
        "--transport",
        "stdio"
      ],
      "enabled": true,
      "environment": {
        "NVD_API_KEY": "ganti-dengan-key-kalian"
      }
    },
    "circl-cve-search": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@iflow-mcp/cyreslab-circl-cve-search-mcp-server"
      ],
      "enabled": true
    },
    "hatchable": {
      "type": "remote",
      "url": "https://hatchable.com/mcp",
      "enabled": true,
      "oauth": {}
    }
  },
  "instructions": [
    "./AGENTS.md",
    "./CLAUDE.md"
  ],
  "keybinds": {
    "leader": "ctrl+k",
    "session_new": "ctrl+n",
    "agent_cycle": "tab"
  },
  "lsp": {
    "typescript": {
      "command": [
        "typescript-language-server",
        "--stdio"
      ],
      "extensions": [
        ".ts",
        ".tsx",
        ".js",
        ".jsx"
      ]
    }
  }
}
